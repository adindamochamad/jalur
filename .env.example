# Salin ke .env dan isi nilai asli. Jangan commit .env.
# Contoh: cp .env.example .env

# MySQL (untuk docker-compose)
MYSQL_ROOT_PASSWORD=isi_password_root_mysql
MYSQL_USER=jalur
MYSQL_PASSWORD=isi_password_user_mysql
MYSQL_DATABASE=jalur

# JWT untuk session login (minimal 32 karakter, acak)
JWT_SECRET=isi_string_rahasia_minimal_32_karakter_acak

# URL frontend/API production (opsional; default docker pakai localhost)
# NEXT_PUBLIC_API_URL=https://your-domain.com
# APP_BASE_URL=https://your-domain.com

# CORS: origin tambahan selain localhost (opsional, pisahkan dengan koma)
# CORS_EXTRA_ORIGINS=https://your-domain.com,http://your-domain.com
